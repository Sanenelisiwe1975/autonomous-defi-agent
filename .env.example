# ============================================================
#  Autonomous DeFi Agent — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ============================================================

#   Network
# Target EVM network (used for logging / contract routing)
NETWORK=sepolia

# JSON-RPC endpoint — Alchemy, Infura, or public node
# Sepolia: https://eth-sepolia.g.alchemy.com/v2/
# Mainnet: https://eth-mainnet.g.alchemy.com/v2/<YOUR_KEY>
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

#   WDK Wallet
# BIP-39 mnemonic for the agent's non-custodial wallet.
# Generate a NEW seed phrase — never reuse a hardware wallet seed.
# The agent uses account index 0 (m/44'/60'/0'/0/0) as primary.
AGENT_SEED_PHRASE="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"

# Maximum fee the agent will pay per transaction, in wei.
# Default: 1_000_000_000_000_000 (0.001 ETH = ~$3 at $3k ETH).
# Increase for high-gas networks; decrease for tighter cost controls.
WALLET_MAX_FEE_WEI=1000000000000000

#  Token Contract Addresses
# USD₮ (USDT) ERC-20 contract — base trading/settlement asset
# Sepolia testnet USDT:   0x7169D38820dfd117C3FA1f22a697dBA58d90BA06
# Ethereum mainnet USDT:  0xdAC17F958D2ee523a2206206994597C13D831ec7
USDT_CONTRACT_ADDRESS=0x7169D38820dfd117C3FA1f22a697dBA58d90BA06

# XAU₮ (Tether Gold) ERC-20 contract — gold hedge reserve asset
# Sepolia testnet XAUT:   (deploy your own test token or use a mock)
# Ethereum mainnet XAUT:  0x68749665FF8D2d112Fa859AA293F07A622782F38
XAUT_CONTRACT_ADDRESS=0x68749665FF8D2d112Fa859AA293F07A622782F38

#  LLM / AI
# Anthropic API key for Claude (used by LangChain.js in packages/planner)
# Get one at https://console.anthropic.com
# If absent, the agent falls back to a deterministic mock planner (no trades).
ANTHROPIC_API_KEY=sk-ant-...

# LLM model to use for reasoning (default: claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6

# LLM temperature (0 = deterministic, 1 = creative; default: 0.2 for finance)
LLM_TEMPERATURE=0.2

# Agent Loop
# How often the agent runs its full Observe→Reason→Decide→Execute→Learn loop
# Value in milliseconds. Default: 60000 (60 seconds)
AGENT_LOOP_INTERVAL_MS=60000

# Set to "true" to log planned actions without submitting transactions.
# ALWAYS start with dry-run=true and verify behaviour before going live.
AGENT_DRY_RUN=true

# Maximum number of loop iterations (leave blank to run indefinitely)
# AGENT_MAX_ITERATIONS=10

# ── Risk Controls ────────────────────────────────────────────
# Minimum expected value for a trade to be approved (default: 0.02 = 2%)
AGENT_MIN_EV=0.02

# Maximum risk score (0–100) for a trade to be approved (default: 70)
AGENT_MAX_RISK_SCORE=70

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (for persisting agent history & learned priors)
DATABASE_URL=postgresql://agent:password@localhost:5432/defi_agent

# Redis connection URL (for caching market signals and rate-limiting)
REDIS_URL=redis://localhost:6379

# ── Smart Contracts ──────────────────────────────────────────
# AgentVault contract address (deployed to Sepolia)
AGENT_VAULT_ADDRESS=

# PredictionMarket factory contract address
MARKET_FACTORY_ADDRESS=

# Private key of the Hardhat deployer account (for contract deployment only)
# Leave blank after deployment — agent uses AGENT_SEED_PHRASE for execution
DEPLOYER_PRIVATE_KEY=

# ── Cross-Chain Bridge (optional) ────────────────────────────
# Max fee for USDT0 LayerZero bridge operations, in wei
BRIDGE_MAX_FEE_WEI=100000000000000

# ── Monitoring ───────────────────────────────────────────────
# Port for the Next.js dashboard (apps/web)
NEXT_PUBLIC_DASHBOARD_PORT=3000

# Agent WebSocket endpoint (consumed by the dashboard)
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:4000
