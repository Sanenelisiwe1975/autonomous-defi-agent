{
  "name": "@repo/wdk",
  "version": "0.1.0",
  "private": true,
  "description": "WDK wrapper — non-custodial EVM wallet management for the DeFi agent",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
